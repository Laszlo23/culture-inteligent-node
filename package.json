{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "tsx --test src/lib/arcium-poa.test.ts src/lib/solana-economy.test.ts src/lib/zk-id/nullifier.test.ts src/lib/main-loop.test.ts src/lib/winning-flows.test.ts src/lib/rain-checklist.test.ts src/lib/first-contribution.test.ts src/lib/bots/attention-miner-core.test.ts",
    "test:arcium-mirror": "tsx --test src/lib/arcium-poa.test.ts",
    "test:economy": "tsx --test src/lib/solana-economy.test.ts",
    "test:zk": "tsx --test src/lib/zk-id/nullifier.test.ts",
    "test:loop": "tsx --test src/lib/main-loop.test.ts src/lib/winning-flows.test.ts src/lib/rain-checklist.test.ts",
    "test:bots": "tsx --test src/lib/bots/attention-miner-core.test.ts",
    "economy:bootstrap": "tsx scripts/devnet-bootstrap.ts",
    "bots:discord-commands": "tsx scripts/register-discord-commands.ts",
    "bots:telegram-webhook": "tsx scripts/set-telegram-webhook.ts",
    "farcaster:validate": "node scripts/validate-farcaster-manifest.mjs",
    "farcaster:validate:signed": "node scripts/validate-farcaster-manifest.mjs --require-association",
    "farcaster:apply-association": "node scripts/apply-farcaster-association.mjs"
  },
  "dependencies": {
    "@farcaster/miniapp-sdk": "^0.3.0",
    "@google/genai": "^2.4.0",
    "@solana/spl-token": "^0.4.15",
    "@solana/web3.js": "^1.98.4",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.22.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tweetnacl": "^1.0.3",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
