# GEMINI_API_KEY: Required for Gemini attention agent verification.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# WALLET_JWT_SECRET: HMAC secret for wallet session tokens (change in production).
WALLET_JWT_SECRET="building-culture-devnet-wallet-secret-v1"

# SOLANA_RPC_URL: Optional Devnet RPC override.
# SOLANA_RPC_URL="https://api.devnet.solana.com"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
