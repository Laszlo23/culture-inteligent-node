# GEMINI_API_KEY: AI coach copy + weekly curriculum research (NOT the PoA pass verifier).
# Confidential pass/fail is Arcium verify_attention_threshold — see docs/ARCIUM_POA.md.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_ARCIUM_RPC: Optional Solana RPC for future on-chain MXE invoke from the wallet client.
# Until set, Academy uses the circuit-mirror in src/lib/arcium-poa.ts (same threshold policy).
# VITE_ARCIUM_RPC="http://127.0.0.1:8899"

# WALLET_JWT_SECRET: REQUIRED in production (server refuses default). Use a long random string.
WALLET_JWT_SECRET="replace-with-a-long-random-secret"

# ALLOW_DEMO_UNSIGNED=1 only for local jury iframes without signMessage (never production).
# ALLOW_DEMO_UNSIGNED="1"

# DEV_OPEN_ADMIN=1 allows curriculum admin when CURRICULUM_ADMIN_WALLETS is empty (local only).
# DEV_OPEN_ADMIN="1"

# CURRICULUM_ADMIN_WALLETS: Comma-separated Solana addresses allowed to draft/publish weekly sessions.
# Empty = deny all (fail-closed) unless DEV_OPEN_ADMIN=1 in non-production.
# CURRICULUM_ADMIN_WALLETS="YourWalletBase58Address"

# Postgres (self-hosted or Cloud SQL)
SQL_HOST="127.0.0.1"
SQL_DB_NAME="culture_node"
SQL_USER="culture_app"
SQL_PASSWORD="change-me"
SQL_ADMIN_USER="culture_admin"
SQL_ADMIN_PASSWORD="change-me"

# SOLANA_RPC_URL: Optional Devnet RPC override.
# SOLANA_RPC_URL="https://api.devnet.solana.com"

# Culture Economy (Devnet) — bootstrap: npx tsx scripts/devnet-bootstrap.ts
# After deploy: ./scripts/devnet-go-live.sh  |  check: npx tsx scripts/check-economy-env.ts
# VITE_* mints MUST be set during `npm run build` (client bake). Never VITE_-prefix the authority.
# VITE_ECONOMY_PROGRAM_ID="AS7E1nsKf3VJGfQPyU5Ekz9iJBNGzZ5sT8P6mGqzbqpZ"
# VITE_BCC_MINT=""
# VITE_CGT_MINT=""
# ECONOMY_AUTHORITY_SECRET=""   # server-only base64 keypair — backup offline, never commit
# Probes: GET /api/health  |  GET /api/ready  |  GET /api/economy/status

# Attention Toll (1¢ USDC micropayments) — treasury wallet receives SPL USDC.
# Devnet USDC mint default is Circle's; override if needed. Rebuild client after VITE_* changes.
# VITE_TOLL_TREASURY="YourTreasuryWalletBase58"
# VITE_USDC_MINT="4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU"

# ZKPassport soulbound reputation — unique human nullifier → NonTransferable mint
# See docs/SOULBOUND_REPUTATION.md
# VITE_ZKPASSPORT_DOMAIN="mining.buildingcultureid.space"
# ZKPASSPORT_SCOPE="culture-node-soulbound-v1"
# ZKPASSPORT_DEV_MODE=1
# VITE_ZKPASSPORT_DEV_MODE=1
# VITE_ZKPASSPORT_SCOPE="culture-node-soulbound-v1"

# APP_URL: The URL where this applet is hosted.
APP_URL="https://mining.buildingcultureid.space"

# PORT: HTTP listen port (nginx proxies here in production).
PORT=3000

# ONCHAINOS_BIN: Path to OKX OnchainOS CLI for /api/market/pulse (default: onchainos on PATH).
# ONCHAINOS_BIN="/usr/local/bin/onchainos"

# NODE_ENV=production
